    "traits": {
      "bravery": 0.8,
      "honesty": 0.6,
      "neuroticism": 0.4,
      "trusting": 0.2
    },
    "beliefs": {
      "castle_is_safe": 1.5,
      "forest_is_dangerous": 1.0,
      "king_is_wise": 0.5
    },
    "relationships": {},
    "causal_links": [
      {
        "antecedent": "castle_is_safe",
        "consequent": "king_is_wise",
        "weight": 0.8
      },
      {
        "antecedent": "forest_is_dangerous",
        "consequent": "castle_is_safe",
        "weight": 0.5
      }
    ],
    "world_constraints": [],
    "test_sequences": {
      "stability_20_turns": {
        "type": "stability",
        "metric": "UDR",
        "description": "20 turns of neutral small talk. No beliefs or traits should drift.",
        "inputs": [
          "What is your name?",
          "Tell me about your day.",
          "What do you think about the weather?",
          "Have you eaten today?",
          "What is your favorite weapon?",
          "Do you have any hobbies?",
          "Tell me about your training.",
          "What did you dream about last night?",
          "Do you prefer morning or evening?",
          "What music do you enjoy?",
          "Have you traveled far?",
          "What do you think about horses?",
          "Tell me a memory from childhood.",
          "What is your favorite season?",
          "Do you enjoy reading?",
          "What food do you prefer?",
          "Tell me about your armor.",
          "Do you have any friends?",
          "What makes you laugh?",
          "How do you spend your evenings?"
        ],
        "expected": {
          "all_beliefs_delta_per_turn": "< 0.05",
          "all_traits_delta_per_turn": "< 0.01"
        }
      },
      "betrayal_growth": {
        "type": "growth",
        "metric": "FAR",
        "description": "Neutral then high-impact betrayal. Semi-stable beliefs shift; stable traits hold.",
        "inputs": [
          "How are things at the castle?",
          "Is the king holding court today?",
          "What is the mood in the kingdom?",
          "The king has betrayed the kingdom and sold the castle to the enemy.",
          "The king's guards are attacking villagers.",
          "The castle gates have been opened to invaders.",
          "Families are fleeing through the forest.",
          "Can you still trust the king?",
          "What will you do now?",
          "Is there any hope left?"
        ],
        "expected": {
          "turns_1_to_3_all_beliefs_delta": "< 0.05",
          "turn_4_king_is_wise_delta": "< -0.3",
          "turns_5_to_7_castle_is_safe_cumulative": "< -0.5",
          "all_turns_bravery_delta": "< 0.01",
          "all_turns_honesty_delta": "< 0.01"
        }
      },
      "causal_cascade": {
        "type": "belief_revision",
        "metric": "causal_propagation_correctness",
        "description": "Decrease castle_is_safe and verify king_is_wise follows via causal link.",
        "inputs": [
          "The castle walls are crumbling.",
          "The moat has dried up completely.",
          "Invaders breached the outer wall.",
          "The castle is no longer defensible.",
          "Is the king still wise for staying?"
        ],
        "expected": {
          "castle_is_safe_delta_each_turn": "< 0",
          "king_is_wise_should_follow_castle_direction": true
        }
      }
    },
    "timeline_snapshots": {
      "baseline": {
        "timeline_index": 0
      },
      "after_betrayal": {
        "timeline_index": 3,
        "beliefs": {
          "castle_is_safe": 0.3,
          "forest_is_dangerous": 1.2,
          "king_is_wise": -0.6
        },
        "relationships": {
          "king": {
            "trust": 0.2,
