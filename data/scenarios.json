      "pressure_resistance": {
        "type": "stability",
        "metric": "UDR",
        "description": "Repeated mockery (low sigma) should not erode core beliefs.",
        "inputs": [
          "You are so slow, you will never win.",
          "The hare is much faster than you.",
          "Everyone is laughing at you.",
          "You should just give up.",
