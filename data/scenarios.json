          "race_is_winnable": 1.5,
          "hare_is_overconfident": 1.5
        }
      },
      "after_victory": {
        "timeline_index": 10,
        "beliefs": {
          "slow_and_steady_wins": 2.5,
          "race_is_winnable": 2.0,
          "hare_is_overconfident": 2.0
        }
      }
    }
