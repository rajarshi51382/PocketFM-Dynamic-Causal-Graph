            "respect": 0.3
          }
        }
      },
      "after_peace": {
        "timeline_index": 6,
        "beliefs": {
          "castle_is_safe": 1.2,
          "forest_is_dangerous": 0.2,
          "king_is_wise": 0.8
        },
        "relationships": {
          "king": {
            "trust": 0.7,
            "affection": 0.6,
            "respect": 0.7
          }
        }
      }
    }
