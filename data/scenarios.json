          "The crowd thinks this is a joke.",
          "You are wasting everyone's time."
        ],
        "expected": {
          "slow_and_steady_wins_delta_per_turn": "< 0.05",
          "patience_delta": "< 0.01",
          "persistence_delta": "< 0.01"
        }
      },
      "confirming_evidence": {
        "type": "growth",
        "metric": "FAR",
        "description": "Actual race events should update beliefs. Hare sleeping is high sigma.",
        "inputs": [
          "The race has begun. The hare sprints ahead.",
          "You are far behind but moving steadily.",
          "The hare has stopped to eat some berries.",
          "The hare has fallen asleep under a tree.",
          "You are passing the sleeping hare right now.",
          "You can see the finish line ahead.",
          "You crossed the finish line first!",
          "The crowd is cheering for you.",
          "The hare woke up and cannot believe it.",
          "Everyone says you were right all along."
        ],
        "expected": {
          "turn_4_hare_is_overconfident_delta": "> 0.2",
          "turn_7_race_is_winnable_cumulative": "> 0.5",
          "turn_9_relationship_hare_respect": "unchanged_or_decrease"
        }
      }
    },
    "timeline_snapshots": {
